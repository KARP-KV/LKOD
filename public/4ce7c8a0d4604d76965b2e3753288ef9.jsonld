  "název": {
    "cs": "Sportovní areály a haly v Karlovarském kraji"
  },
  "popis": {
    "cs": "Datová sada obsahuje přehled sportovních areálů a sportovních hal v Karlovarském kraji s jejich přesnou prostorovou lokalizací. K jednotlivým sportovním areálům a halám je uveden název, specifikace typu, popis, provozovatel (název, identifikační číslo, právní forma, sídlo, kód adresy a ID datové schránky), telefonní kontakt, kontaktní e-mail, adresa místa a souřadnice. Souřadnicový systém je použit WGS 1984.Zdrojem dat je Krajské inovační centrum Karlovarského kraje, p.o."
  },
  "klíčové_slovo": {
    "cs": [
      "Sportovní areál",
      "Sportovní centrum",
      "sportovní hala",
      "zimní stadion",
      "stadion",
      "Karlovarský kraj",
      "sport"
    ]
  },
