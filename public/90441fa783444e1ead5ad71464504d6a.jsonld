  "název": {
    "cs": "Lanová a zábavní centra v Karlovarském kraji"
  },
  "popis": {
    "cs": "Datová sada obsahuje přehled lanových a zábavních center na území Karlovarského kraje. Uvedené informace: název, provozovatel centra (jeho název, identifikační číslo, právní forma, sídlo, kód adresy, číslo datové schránky), informace o přístupnosti a vstupném, webové stránky centra, kontaktní údaje - kontaktní telefon a kontaktní e-mail, a prostorovou lokalizaci centra. Souřadnicový systém je použit WGS 1984.Zdrojem dat je Krajské inovační centrum Karlovarského kraje, p.o."
  },
  "klíčové_slovo": {
    "cs": [
      "Karlovarský kraj",
      "zábavní centrum",
      "lanové centrum"
    ]
  },
