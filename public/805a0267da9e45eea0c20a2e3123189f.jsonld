  "název": {
    "cs": "Divadla v Karlovarském kraji"
  },
  "popis": {
    "cs": "Datová sada obsahuje přehled divadel a divadelních prostor na území Karlovarského kraje, obsahuje údaje: název, adresa místa, provozovatel (název, identifikační číslo, právní forma, sídlo, kód adresy, ID datové schránky), webová stránka, kontaktní e-mail, kontaktní telefonní číslo a přesnou prostorovou lokalizaci umístění divadla či divatelního prostoru. Souřadnicový systém je použit WGS 1984.Poskytovatelem dat je Krajské inovační centrum Karlovarského kraje, p.o."
  },
  "klíčové_slovo": {
    "cs": [
      "divadlo",
      "Karlovarský kraj",
      "divadelní prostor"
    ]
  },
