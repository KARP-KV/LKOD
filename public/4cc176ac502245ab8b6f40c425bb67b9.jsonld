  "název": {
    "cs": "Jezdecké oddíly a kluby v Karlovarském kraji"
  },
  "popis": {
    "cs": "Datová sada obsahuje přehled jezdeckých oddílů a klubů na území Karlovarského kraje. Datová sada obsahuje jak oficiální sportovní oddíly jako zapsané spolky tak soukromé komerční areály vedené pod živnostenským oprávněním, které však fakticky plní roli jezdeckých klubů pro veřejnost. Obsažená data: název, adresa místa, popis, provozovatel (identifikační číslo, právní forma, sídlo), webová stránka, kontaktní e-mail, telefonní kontakt a prostorová specifikace místa provozu. Souřadnicový systém je použit WGS 1984.Zdrojem dat je Krajské inovační centrum Karlovarského kraje, p.o."
  },
  "klíčové_slovo": {
    "cs": [
      "jezdecký oddíl",
      "jezdecký klub",
      "Karlovarský kraj"
    ]
  },
