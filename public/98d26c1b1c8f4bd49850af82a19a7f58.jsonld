  "název": {
    "cs": "Aquaparky, koupaliště a bazény v Karlovarském kraji"
  },
  "popis": {
    "cs": "Datová sada obsahuje přehled aquaparků, koupališť a bazénů v Karlovarském kraji, obsahuje informace: název, typ, informace o vstupném, provozovatel (název, identifikační číslo, právní forma, sídlo, kód adresy, ID datové schránky), webové stránky, kontaktní e-mail a telefonní číslo a přesnou prostorovou lokalizaci zařízení. Souřadnicový systém je použit WGS 1984.Zdrojem dat je Krajské inovační centrum Karlovarského kraje, p.o."
  },
  "klíčové_slovo": {
    "cs": [
      "aquapark",
      "koupaliště",
      "bazén",
      "Karlovarský kraj"
    ]
