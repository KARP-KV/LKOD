  "název": {
    "cs": "Letiště v Karlovarském kraji"
  },
  "popis": {
    "cs": "Datová sada obsahuje přehled vnitrostátních, mezinárodních letišť a významných ploch pro sportovní létající zařízení na území Karlovarského kraje. Uvedené údaje: název, provozovatel letiště, jeho název, identifikační číslo, sídlo, právní forma, kontaktní e-mail, telefonní kontakt, číslo datové schránky, webové stránky letiště, informace o letišti - kódy letiště, druh letiště, informace o dráze, nadmořská výška letiště, datum otevření a prostorová lokalizace letiště. Souřadnicový systém je využit WGS 1984.&nbsp;Zdrojem dat je Krajské inovační centrum Karlovarského kraje, p.o."
  },
  "klíčové_slovo": {
    "cs": [
      "Karlovarský kraj",
      "letiště",
      "vnitrostátní letiště",
      "mezinárodní letiště",
      "plocha pro sportovní létající zařízení"
    ]
  },
