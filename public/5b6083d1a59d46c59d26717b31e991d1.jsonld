  "název": {
    "cs": "Archeologické památky v Karlovarském kraji"
  },
  "popis": {
    "cs": "Datová sada obsahuje přehled archeologických památek na území Karlovarského kraje. Obsahuje informace: název, typ památky, informace o památkové ochraně a fázi ochrany, stručný popis, poznámka, informace o přístupnosti a vstupném, webové stránky s informacemi o památce prostorovou specifikaci místa památky. Souřadnicový systém je použit WGS 1984.Zdrojem dat je Krajské inovační centrum Karlovarského kraje, p.o."
  },
  "klíčové_slovo": {
    "cs": [
      "Karlovarský kraj",
      "archeologie",
      "památka",
      "archeologická památka",
